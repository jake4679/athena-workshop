{
  "server": {
    "port": 3000,
    "pollIntervalMs": 3000,
    "resultsDir": "/data/results",
    "startupRetryCount": 20,
    "startupRetryDelayMs": 3000
  },
  "auth": {
    "mode": "oidc",
    "baseURL": "http://localhost:3000",
    "sessionSecret": "change-me-session-secret",
    "sessionCookieName": "athena.sid",
    "sessionMaxAgeMs": 604800000,
    "secureCookies": false,
    "devUser": {
      "id": "dev-user-local",
      "email": "dev@example.com",
      "firstName": "Dev",
      "lastName": "User",
      "roles": ["admin", "querier", "viewer"]
    },
    "google": {
      "issuer": "https://accounts.google.com",
      "clientId": "change-me-google-client-id",
      "clientSecret": "change-me-google-client-secret"
    }
  },
  "aws": {
    "region": "us-east-1",
    "profile": "default",
    "catalog": "AwsDataCatalog",
    "outputLocation": "s3://your-athena-query-results-bucket/prefix/",
    "workGroup": "primary"
  },
  "assistant": {
    "provider": "openai",
    "apiKeyEnvVar": "ASSISTANT_API_KEY",
    "apiKey": "",
    "assistantSeedInstruction": "You are a SQL assistant for AWS Athena. Provide concise, practical guidance and valid Athena SQL.",
    "maxToolRounds": 1000
  },
  "tools": {
    "defaultTimeoutMs": 10000,
    "defaultMaxCallsPerRun": 3,
    "credentialSets": {
      "logsS3": {
        "AWS_ACCESS_KEY_ID": "",
        "AWS_SECRET_ACCESS_KEY": "",
        "AWS_SESSION_TOKEN": "",
        "AWS_REGION": "us-east-1",
        "AWS_DEFAULT_REGION": "us-east-1"
      }
    },
    "userSupplied": [
      {
        "name": "fetch_logs",
        "description": "Download relevant logs from S3.",
        "tags": ["logs", "s3"],
        "inputSchema": {
          "type": "object",
          "properties": {
            "prefix": {
              "type": "string"
            }
          },
          "required": ["prefix"],
          "additionalProperties": false
        },
        "runner": {
          "type": "exec",
          "command": ["node", "./scripts/tools/fetch-logs.js"],
          "credentialSet": "logsS3",
          "env": {
            "LOG_BUCKET": "example-log-bucket"
          },
          "timeoutMs": 15000,
          "maxCallsPerRun": 2
        }
      }
    ]
  },
  "providers": {
    "openai": {
      "model": "gpt-5",
      "baseURL": "https://api.openai.com/v1"
    },
    "anthropic": {
      "model": "claude-sonnet-4-5",
      "baseURL": "https://api.anthropic.com",
      "version": "2023-06-01",
      "maxTokens": 2048
    }
  },
  "mysql": {
    "host": "athena-mysql",
    "port": 3306,
    "user": "athena",
    "password": "change-me-app-password",
    "database": "athena_manager",
    "connectionLimit": 10
  }
}
