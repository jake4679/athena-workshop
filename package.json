{
  "name": "athena-query-manager",
  "version": "1.0.0",
  "description": "Minimal HTTP server for managing AWS Athena queries",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js --config ./config.json",
    "start:dev": "node src/server.js --config ./config.json",
    "admin": "node ./scripts/admin.js --config ./config.json",
    "test": "node --test",
    "test:post-query": "node --test tests/query.create.test.js",
    "test:post-query:report": "bash ./scripts/run-test-report.sh tests/query.create.test.js",
    "test:cancel-query": "node --test tests/query.cancel.test.js",
    "test:cancel-query:report": "bash ./scripts/run-test-report.sh tests/query.cancel.test.js"
  },
  "dependencies": {
    "@aws-sdk/client-athena": "^3.864.0",
    "express": "^4.21.2",
    "express-mysql-session": "^3.0.3",
    "express-session": "^1.19.0",
    "mysql2": "^3.14.5",
    "openid-client": "^6.8.2",
    "uuid": "^11.1.0"
  }
}
